---
import { menuLinks, siteConfig } from "@/site.config";

const year = new Date().getFullYear();
---

<footer
	class="text-muted mt-auto flex w-full items-center justify-between pt-20 pb-4 text-sm font-semibold"
>
	<div>
		&copy; {year} {siteConfig.author}
	</div>

	<div class="flex items-center gap-2">
		<svg
			xmlns="http://www.w3.org/2000/svg"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="1.8"
			stroke-linecap="round"
			stroke-linejoin="round"
			class="h-5 w-5"
			aria-hidden="true"
		>
			<rect x="3" y="5" width="18" height="14" rx="2" />
			<path d="M3 7l9 7 9-7" />
		</svg>

		<span>pallavitekta@gmail.com</span>
	</div>
</footer>
